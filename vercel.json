{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/drugs",
      "dest": "/api/drugs.py"
    },
    {
      "src": "/api/drugs/add",
      "dest": "/api/add-drug.py"
    },
    {
      "src": "/api/drugs/import-huggingface",
      "dest": "/api/import-huggingface.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
